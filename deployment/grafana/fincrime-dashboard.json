{
  "title": "FinCrime - Model & API Health",
  "uid": "fincrime-overview",
  "tags": ["fincrime", "aml", "ml"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Predictions / sec (all layers)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(rate(fincrime_predictions_total[1m]))", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 2, "type": "stat", "title": "Alert rate (5m)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(fincrime_alerts_total[5m])) / clamp_min(sum(rate(fincrime_predictions_total[5m])), 0.001)",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": {
        "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 0.1 },
          { "color": "red", "value": 0.3 }
        ]
      } } }
    },
    {
      "id": 3, "type": "stat", "title": "API p95 latency",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le) (rate(fincrime_api_request_duration_seconds_bucket[5m])))",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4, "type": "stat", "title": "Total reports generated",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "sum(fincrime_reports_total)", "refId": "A" }]
    },
    {
      "id": 10, "type": "timeseries", "title": "Predictions per second by layer",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (layer) (rate(fincrime_predictions_total[1m]))", "refId": "A", "legendFormat": "{{layer}}" }]
    },
    {
      "id": 11, "type": "timeseries", "title": "Alerts per minute by severity",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (severity) (rate(fincrime_alerts_total[1m]))", "refId": "A", "legendFormat": "{{severity}}" }]
    },
    {
      "id": 20, "type": "timeseries", "title": "API request rate by endpoint",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (endpoint) (rate(fincrime_api_requests_total[1m]))", "refId": "A", "legendFormat": "{{endpoint}}" }]
    },
    {
      "id": 21, "type": "timeseries", "title": "API p50/p95/p99 latency",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(fincrime_api_request_duration_seconds_bucket[5m])))", "refId": "A", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(fincrime_api_request_duration_seconds_bucket[5m])))", "refId": "B", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(fincrime_api_request_duration_seconds_bucket[5m])))", "refId": "C", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 30, "type": "stat", "title": "Open cases",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 4 },
      "targets": [{ "expr": "sum by (status) (fincrime_cases_open)", "refId": "A", "legendFormat": "{{status}}" }]
    }
  ]
}
