# ===== Application =====
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_DATA_DIR=./data
APP_MODELS_DIR=./data/models

# ===== Layer 2: Neo4j =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=fincrime-dev-password

# ===== Blockchain RPC =====
# Satu key Etherscan (V2) meng-cover ETH + BSC + Polygon + 60 chain EVM lain.
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY_HERE
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
# Opsional — fallback legacy per-chain (tidak perlu jika ETHERSCAN_API_KEY terisi):
BSCSCAN_API_KEY=
POLYGONSCAN_API_KEY=
# Opsional — Tron jalan tanpa key; key menaikkan rate limit (trongrid.io):
TRONGRID_API_KEY=

# ===== LLM Narrative (Layer 3) =====
# Narasi LTKM ditulis Claude; tanpa key, fallback ke template offline.
# Ambil di https://console.anthropic.com
ANTHROPIC_API_KEY=

# ===== Telegram Bot =====
# Buat bot via @BotFather di Telegram, salin token-nya ke sini.
TELEGRAM_BOT_TOKEN=
# Opsional — batasi user yang boleh pakai bot (comma-separated Telegram user IDs):
TELEGRAM_ALLOWED_USERS=

# ===== Kafka =====
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_BANK=fincrime.bank.transactions
KAFKA_TOPIC_EWALLET=fincrime.ewallet.transactions
KAFKA_TOPIC_CRYPTO=fincrime.crypto.transactions
KAFKA_TOPIC_ALERTS=fincrime.alerts

# ===== API =====
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production
API_CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# ===== PPATK =====
PPATK_ENDPOINT=https://api.ppatk.go.id/v1/ltkm  # placeholder
PPATK_API_KEY=YOUR_PPATK_KEY_HERE
PPATK_INSTITUTION_CODE=BANK001

# ===== Thresholds =====
RISK_SCORE_HIGH=70
RISK_SCORE_CRITICAL=85
FRAUD_ANOMALY_THRESHOLD=0.7
GNN_LAYERING_THRESHOLD=0.6
